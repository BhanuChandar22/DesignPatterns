//Bill Pugh Singleton thread-safe
class DBConnection{
    private DBConnection(){
    }
    private static class DBConnHelper{
        private static final DBConnection instance = new DBConnection();
    }
    public static DBConnection getConnectionObj(){
        return DBConnHelper.instance;
    }
}

class Main extends Thread {
    public void run(){
        System.out.println(DBConnection.getConnectionObj()+" ::"+Thread.currentThread().getName());
    }
    public static void main(String[] args) {
        // System.out.println(DBConnection.getConnectionObj());
        // System.out.println(DBConnection.getConnectionObj());
        for(int i=0;i<10;i++){
            Thread t = new Thread(new Main());
            t.start();
        }

    }
}

